# =====================================================
#  AI JOB & CLIENT HUNTER AGENT - Environment Config
# =====================================================

# --- ANTHROPIC (Claude AI) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- SERP API (Google Search) ---
# Get free key at: https://serpapi.com  (100 free searches/month)
SERPAPI_KEY=your_serpapi_key_here

# --- GMAIL API ---
# Follow setup guide in README.md to get these
GMAIL_SENDER_EMAIL=your.email@gmail.com
GMAIL_CREDENTIALS_FILE=credentials/gmail_credentials.json
GMAIL_TOKEN_FILE=credentials/gmail_token.pickle

# --- TELEGRAM BOT (Notifications) ---
# Create bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- HUNTER.IO (Find business emails from domains) ---
# Get free key at: https://hunter.io (25 free searches/month)
HUNTERIO_API_KEY=your_hunterio_api_key_here

# --- AGENT SETTINGS ---
# How often agent runs (in hours)
AGENT_RUN_INTERVAL_HOURS=24
# Max leads to process per run
MAX_LEADS_PER_RUN=20
# Minimum match score (0-100) to contact a lead
MIN_MATCH_SCORE=65
# Auto send emails? false = agent drafts, you approve; true = fully automatic
AUTO_SEND_EMAILS=false
# Auto reply to responses?
AUTO_REPLY_ENABLED=true
